generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  country      String        @default("US")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  scans        Scan[]
  credits      Credit?
  transactions Transaction[]
}

model Scan {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  documentType String
  country      String
  tier         String
  status       String   @default("pending") // pending, paid, extracting, analyzing, completed, failed
  filePath     String?
  extractedText String?
  summary      String?  // Plain-English document summary
  errorMessage String?
  resources    String?  // JSON string of resource directory
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  flags        Flag[]

  @@index([userId])
}

model Flag {
  id                String @id @default(uuid())
  scanId            String
  scan              Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  flag_title        String
  severity          String // high, medium, low
  plain_english     String
  estimated_impact  String @default("")
  regulation_cited  String @default("")
  recommended_action String @default("")

  @@index([scanId])
}

model Credit {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model InviteCode {
  id        String   @id @default(uuid())
  code      String   @unique
  usedBy    String?  // userId who redeemed it
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  scanId          String?
  amount          Int      // cents
  tier            String
  stripePaymentId String?  @unique
  stripeSessionId String?  @unique
  status          String   @default("pending") // pending, completed, failed
  createdAt       DateTime @default(now())

  @@index([userId])
}
